{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 10
  },
  "configurePresets": [
    {
      "name": "default",
      "description": "Base configuration for all builds",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_CXX_STANDARD": "17",
        "CMAKE_CXX_STANDARD_REQUIRED": "ON"
      }
    },
    {
      "name": "debug",
      "description": "Debug build with no optimizations",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0 -g"
      }
    },
    {
      "name": "release",
      "description": "Release build with optimizations and LTO",
      "inherits": "default",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3 -flto -march=native -fno-rtti -fno-exceptions"
      }
    },
    {
      "name": "test",
      "description": "Debug build with testing enabled",
      "inherits": "debug",
      "cacheVariables": {
        "ENABLE_TESTING": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "build-debug",
      "description": "Build the Debug preset",
      "configurePreset": "debug"
    },
    {
      "name": "build-release",
      "description": "Build the Release preset",
      "configurePreset": "release"
    },
    {
      "name": "build-test",
      "description": "Build the Test preset",
      "configurePreset": "test"
    }
  ],
  "testPresets": [
    {
      "name": "run-tests",
      "description": "Run all tests via CTest",
      "configurePreset": "test"
    }
  ]
}