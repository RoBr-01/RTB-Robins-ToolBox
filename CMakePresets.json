{
    "version": 3,
    "configurePresets": [
        {
            "name": "default",
            "description": "Base configuration for all builds",
            "hidden": true,
            "generator": "Ninja"
        },
        {
            "name": "debug",
            "description": "Debug build with no optimizations",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug"
            }
        },
        {
            "name": "release",
            "description": "Release build with optimizations and LTO",
            "inherits": "default",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        },
        {
            "name": "test",
            "description": "Debug build with testing enabled",
            "inherits": "debug",
            "cacheVariables": {
                "BUILD_TESTS": "ON"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "build-debug",
            "description": "Build the Debug preset",
            "configurePreset": "debug",
            "configuration": "Debug"
        },
        {
            "name": "build-release",
            "description": "Build the Release preset",
            "configurePreset": "release",
            "configuration": "Release"
        },
        {
            "name": "build-test",
            "description": "Build the Test preset",
            "configurePreset": "test"
        }
    ]
}